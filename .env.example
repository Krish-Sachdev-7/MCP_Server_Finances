# EquityMCP Configuration

# Transport: 'http' for remote (Streamable HTTP), 'stdio' for local Claude Desktop
TRANSPORT=http
PORT=3000

# Database
DATABASE_URL=postgresql://equitymcp:equitymcp_dev_password@localhost:5432/equitymcp

# Redis
REDIS_URL=redis://localhost:6379

# Authentication (comma-separated API keys)
EQUITY_MCP_API_KEYS=dev-key-12345

# Rate limiting
RATE_LIMIT_RPM=100
RATE_LIMIT_RPD=5000

# Logging
LOG_LEVEL=info

# Environment
NODE_ENV=development
